# Deployment mode gates whether Forge may touch the network at all.
#   commercial  -> network retrieval allowed (part-number lookup via Nexar, scrape fallback),
#                  and cloud extraction (Gemini) permitted as a demo-only fallback
#   air-gapped  -> upload only, zero network egress, no cloud model calls
#
# When unset or unrecognized the default is environment-aware:
#   - local dev / tests : commercial, so a fresh checkout works with no setup
#   - production build   : air-gapped, so a misconfigured prod deploy denies rather than leaks
# The consumer SaaS is a production deploy and needs network, so it MUST set this to
# commercial explicitly. A prod box that reaches the network should say so on purpose.
FORGE_DEPLOYMENT_MODE=commercial

# Nexar (Octopart) credentials for the primary commercial-path resolver (Layer 1 retrieval).
# Only read in commercial mode. When unset, the Nexar resolver reports itself not configured and
# the commercial path falls back to the scrape resolver, so the app still runs without them.
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=

# Google Gemini key for the cloud extraction path (Layer 2, demo only). GATED TO COMMERCIAL MODE:
# the routes reach Gemini only through a dynamic import inside a commercial-mode branch, so in
# air-gapped mode this key is ignored and the deterministic parser is used. Never rely on Gemini
# for air-gapped extraction; that path must be a locally hostable open-weight model.
GOOGLE_GEMINI_API_KEY=
